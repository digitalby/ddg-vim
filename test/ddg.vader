" test/ddg.vader — vader.vim test suite for ddg.vim
"
" Run manually (from repo root):
"   vim -u test/ci_vimrc -N --not-a-term -c 'Vader! test/ddg.vader'
"
" Or via the CI workflow: push to main / open a PR.
"
" Non-ASCII strings are built with nr2char(codepoint, 1) rather than
" written as literals so the tests are independent of the runner's locale
" and the file's on-disk encoding.
"
" Local variables (l:) are not permitted outside functions in Vim.
" Vader Execute blocks run in script scope, so bare variable names are used.

" ----------------------------------------------------------------------------
" Global setup: mock the browser with a capture script.
" vader runs Before/Execute blocks in separate script contexts, so shared
" state must use g: variables, not s: variables.
" ----------------------------------------------------------------------------

Before:
  let g:ddg_tmpfile = tempname()
  let $DDG_CAPTURE_FILE = g:ddg_tmpfile
  let g:ddg_open_command = g:ddg_test_dir . '/capture_url.sh'

After:
  unlet! g:ddg_open_command
  let $DDG_CAPTURE_FILE = ''
  silent! call delete(g:ddg_tmpfile)
  unlet! g:ddg_tmpfile

" ----------------------------------------------------------------------------
" ddg#URLEncode — pure encoding tests (no browser involved)
" ----------------------------------------------------------------------------

Execute (spaces become plus signs):
  AssertEqual 'hello+world', ddg#URLEncode('hello world')

Execute (RFC 3986 unreserved chars pass through unchanged):
  AssertEqual 'abc-_.~ABC123', ddg#URLEncode('abc-_.~ABC123')

Execute (slash is percent-encoded):
  AssertEqual 'foo%2Fbar', ddg#URLEncode('foo/bar')

Execute (ampersand is percent-encoded):
  AssertEqual 'a%26b', ddg#URLEncode('a&b')

Execute (hash is percent-encoded):
  AssertEqual '%23hash', ddg#URLEncode('#hash')

Execute (question mark is percent-encoded):
  AssertEqual 'what%3F', ddg#URLEncode('what?')

Execute (equals sign is percent-encoded):
  AssertEqual 'a%3Db', ddg#URLEncode('a=b')

Execute (plus sign is percent-encoded, not treated as space):
  AssertEqual '%2B', ddg#URLEncode('+')

Execute (percent sign is percent-encoded):
  AssertEqual '%25', ddg#URLEncode('%')

Execute (multiple consecutive spaces each become plus):
  AssertEqual 'a++b', ddg#URLEncode('a  b')

Execute (tab is percent-encoded):
  AssertEqual 'a%09b', ddg#URLEncode("a\tb")

Execute (empty string returns empty string):
  AssertEqual '', ddg#URLEncode('')

" Latin-1 supplemental: é = U+00E9 → UTF-8 bytes C3 A9
Execute (Latin-1 supplemental is UTF-8 percent-encoded):
  AssertEqual 'caf%C3%A9', ddg#URLEncode('caf' . nr2char(0xE9, 1))

" Cyrillic: привет — п=U+043F р=U+0440 и=U+0438 в=U+0432 е=U+0435 т=U+0442
Execute (Cyrillic is UTF-8 percent-encoded correctly):
  let privet = nr2char(0x43F, 1) . nr2char(0x440, 1) . nr2char(0x438, 1)
    \ . nr2char(0x432, 1) . nr2char(0x435, 1) . nr2char(0x442, 1)
  AssertEqual '%D0%BF%D1%80%D0%B8%D0%B2%D0%B5%D1%82', ddg#URLEncode(privet)

" CJK: 日本語 — 日=U+65E5  本=U+672C  語=U+8A9E
Execute (CJK 3-byte chars are UTF-8 percent-encoded correctly):
  let nihongo = nr2char(0x65E5, 1) . nr2char(0x672C, 1) . nr2char(0x8A9E, 1)
  AssertEqual '%E6%97%A5%E6%9C%AC%E8%AA%9E', ddg#URLEncode(nihongo)

" Emoji: 🔍 = U+1F50D → UTF-8 bytes F0 9F 94 8D
Execute (emoji 4-byte chars are UTF-8 percent-encoded correctly):
  AssertEqual '%F0%9F%94%8D', ddg#URLEncode(nr2char(0x1F50D, 1))

" Arabic: بحث — ب=U+0628  ح=U+062D  ث=U+062B
Execute (Arabic is UTF-8 percent-encoded correctly):
  let bht = nr2char(0x628, 1) . nr2char(0x62D, 1) . nr2char(0x62B, 1)
  AssertEqual '%D8%A8%D8%AD%D8%AB', ddg#URLEncode(bht)

" Mixed ASCII + CJK: vim 教程 — 教=U+6559  程=U+7A0B
Execute (mixed ASCII and CJK encodes correctly):
  let mixed = 'vim ' . nr2char(0x6559, 1) . nr2char(0x7A0B, 1)
  AssertEqual 'vim+%E6%95%99%E7%A8%8B', ddg#URLEncode(mixed)

" ----------------------------------------------------------------------------
" ddg#Search — integration tests (browser mocked via capture script)
" ----------------------------------------------------------------------------

Execute (single word builds correct URL):
  call ddg#Search('vim')
  AssertEqual 'https://duckduckgo.com/?q=vim', readfile(g:ddg_tmpfile)[0]

Execute (multiple words encode spaces as plus):
  call ddg#Search('hello world')
  AssertEqual 'https://duckduckgo.com/?q=hello+world', readfile(g:ddg_tmpfile)[0]

Execute (leading and trailing whitespace is trimmed):
  call ddg#Search('  trimmed  ')
  AssertEqual 'https://duckduckgo.com/?q=trimmed', readfile(g:ddg_tmpfile)[0]

Execute (special characters in query are encoded):
  call ddg#Search('a&b=c')
  AssertEqual 'https://duckduckgo.com/?q=a%26b%3Dc', readfile(g:ddg_tmpfile)[0]

Execute (Cyrillic search builds correct URL):
  let privet = nr2char(0x43F, 1) . nr2char(0x440, 1) . nr2char(0x438, 1)
    \ . nr2char(0x432, 1) . nr2char(0x435, 1) . nr2char(0x442, 1)
  call ddg#Search(privet)
  AssertEqual 'https://duckduckgo.com/?q=%D0%BF%D1%80%D0%B8%D0%B2%D0%B5%D1%82',
    \ readfile(g:ddg_tmpfile)[0]

Execute (empty query is rejected with an error):
  let v:errmsg = ''
  silent! call ddg#Search('')
  Assert v:errmsg =~# 'must not be empty', 'Expected error for empty query'
